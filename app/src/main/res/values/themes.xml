<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme -->
    <style name="Base.Theme.Prm392_kitchen_mobile" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Màu chính của app -->
        <item name="colorPrimary">@color/colorPrimary</item>
        <!-- Màu container (nền nhạt hơn colorPrimary) -->
        <item name="colorPrimaryContainer">@color/colorPrimaryLight</item>
        <!-- Màu phụ -->
        <item name="colorSecondary">@color/colorSecondary</item>
        <!-- Nền bề mặt (card, dialog) -->
        <item name="colorSurface">@color/colorSurface</item>
        <!-- Chữ trắng trên nền cam -->
        <item name="colorOnPrimary">@color/colorOnPrimary</item>
        <!-- Chữ đen trên nền trắng -->
        <item name="colorOnSurface">@color/colorTextPrimary</item>
        <!-- Màu lỗi -->
        <item name="colorError">@color/colorError</item>
        <!-- Nền app -->
        <item name="android:colorBackground">@color/colorBackground</item>
        <!-- Màu thanh status bar (trên cùng điện thoại) -->
        <item name="android:statusBarColor">@color/colorPrimary</item>
        <!-- Màu thanh navigation bar (dưới cùng điện thoại) -->
        <item name="android:navigationBarColor">@color/colorSurface</item>
    </style>

    <style name="Theme.Prm392_kitchen_mobile" parent="Base.Theme.Prm392_kitchen_mobile" />

    <!-- Navbar text styles -->
    <style name="NavBarTextActive" parent="TextAppearance.Material3.LabelSmall">
        <item name="android:textSize">11sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="NavBarTextInactive" parent="TextAppearance.Material3.LabelSmall">
        <item name="android:textSize">10sp</item>
    </style>

    <!-- Style cho Indicator (vòng tròn/pill bao quanh icon active) -->
    <style name="App.Custom.Indicator" parent="Widget.Material3.BottomNavigationView.ActiveIndicator">
        <item name="android:color">@color/colorSecondary</item>
        <item name="marginHorizontal">4dp</item>
    </style>
</resources>
