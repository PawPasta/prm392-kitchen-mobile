<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorBackground">

    <androidx.core.widget.NestedScrollView
        android:id="@+id/homeScroll"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="24dp">

            <!-- HEADER GRADIENT -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="20dp"
                android:paddingTop="20dp"
                android:paddingEnd="20dp"
                android:paddingBottom="40dp"
                android:background="@drawable/bg_gradient_primary">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tvWelcome"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Xin chào!"
                        android:textColor="@color/white"
                        android:textSize="20sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvUserInfo"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="Bạn muốn ăn gì hôm nay?"
                        android:textColor="#CCFFFFFF"
                        android:textSize="13sp" />
                </LinearLayout>

                <ImageView
                    android:id="@+id/ivNotification"
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:contentDescription="@string/app_name"
                    android:src="@drawable/ic_notification"
                    app:tint="@color/white" />
            </LinearLayout>

            <!-- SEARCH BAR -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginHorizontal="20dp"
                android:layout_marginTop="-24dp"
                android:background="@drawable/bg_home_search_bar"
                android:elevation="2dp"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Tìm kiếm món ăn..."
                    android:textColor="@color/colorTextSecondary"
                    android:textSize="14sp" />
            </LinearLayout>

            <!-- DANH MỤC -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="20dp"
                android:layout_marginTop="20dp"
                android:text="Danh mục"
                android:textColor="@color/colorTextPrimary"
                android:textSize="18sp"
                android:textStyle="bold" />

            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:scrollbars="none"
                android:paddingHorizontal="16dp"
                android:clipToPadding="false">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:id="@+id/categoryCarb"
                        android:layout_width="80dp"
                        android:layout_height="80dp"
                        android:layout_marginHorizontal="4dp"
                        android:background="@drawable/bg_category_tile"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:padding="2dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="🍚" android:textSize="24sp" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="1dp" android:text="Carb" android:textColor="@color/colorTextPrimary" android:textSize="11sp" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/categoryProtein"
                        android:layout_width="80dp"
                        android:layout_height="80dp"
                        android:layout_marginHorizontal="4dp"
                        android:background="@drawable/bg_category_tile"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:padding="2dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="🍗" android:textSize="24sp" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="1dp" android:text="Protein" android:textColor="@color/colorTextPrimary" android:textSize="11sp" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/categoryVegetables"
                        android:layout_width="80dp"
                        android:layout_height="80dp"
                        android:layout_marginHorizontal="4dp"
                        android:background="@drawable/bg_category_tile"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:padding="2dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="🥦" android:textSize="24sp" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="1dp" android:text="Vegetables" android:textColor="@color/colorTextPrimary" android:textSize="9sp" android:maxLines="2" android:gravity="center" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/categorySauce"
                        android:layout_width="80dp"
                        android:layout_height="80dp"
                        android:layout_marginHorizontal="4dp"
                        android:background="@drawable/bg_category_tile"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:padding="2dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="🥣" android:textSize="24sp" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="1dp" android:text="Sauce" android:textColor="@color/colorTextPrimary" android:textSize="11sp" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/categoryExtra"
                        android:layout_width="80dp"
                        android:layout_height="80dp"
                        android:layout_marginHorizontal="4dp"
                        android:background="@drawable/bg_category_tile"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:padding="2dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="✨" android:textSize="24sp" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="1dp" android:text="Extra" android:textColor="@color/colorTextPrimary" android:textSize="11sp" />
                    </LinearLayout>

                </LinearLayout>
            </HorizontalScrollView>

            <!-- BANNER CAROUSEL -->
            <androidx.viewpager2.widget.ViewPager2
                android:id="@+id/bannerPager"
                android:layout_width="match_parent"
                android:layout_height="180dp"
                android:layout_marginHorizontal="20dp"
                android:clipToPadding="false"
                android:clipChildren="false"
                android:layout_marginTop="32dp" />

            <LinearLayout
                android:id="@+id/bannerIndicators"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="12dp"
                android:orientation="horizontal" />

            <!-- MÓN PHỔ BIẾN -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="20dp"
                android:layout_marginTop="32dp"
                android:text="Món phổ biến 🌟"
                android:textColor="@color/colorTextPrimary"
                android:textSize="18sp"
                android:textStyle="bold" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvDishes"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:layout_marginHorizontal="20dp"
                android:nestedScrollingEnabled="false" />



        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</FrameLayout>
