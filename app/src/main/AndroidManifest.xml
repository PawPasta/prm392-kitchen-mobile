<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Permissions -->
    <uses-permission android:name="android.permission.INTERNET" />

    <application
        android:name=".KitchenApplication"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.Prm392_kitchen_mobile"
        android:usesCleartextTraffic="true">

        <!-- SplashActivity - Màn hình khởi động (LAUNCHER) -->
        <activity
            android:name=".activities.SplashActivity"
            android:exported="true"
            android:theme="@style/Theme.Prm392_kitchen_mobile">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- AuthActivity - Màn hình đăng nhập -->
        <activity
            android:name=".activities.AuthActivity"
            android:exported="false" />

        <!-- MainActivity - Routes/Navigation chính -->
        <activity
            android:name=".MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data
                    android:scheme="chickenapp"
                    android:host="payment-success" />
            </intent-filter>
        </activity>

        <!-- DishDetailActivity - Chi tiết món ăn -->
        <activity
            android:name=".activities.DishDetailActivity"
            android:exported="false" />

        <!-- ProfileActivity - User profile -->
        <activity
            android:name=".activities.ProfileActivity"
            android:exported="false" />

        <!-- CreateOrderActivity - Tạo đơn hàng từ dish -->
        <activity
            android:name=".activities.CreateOrderActivity"
            android:exported="false" />

        <!-- CreateCustomOrderActivity - Tạo đơn hàng custom -->
        <activity
            android:name=".activities.CreateCustomOrderActivity"
            android:exported="false" />

        <!-- OrderHistoryActivity - Order history -->
        <activity
            android:name=".activities.OrderHistoryActivity"
            android:exported="false" />

        <!-- CartActivity - Cart orders (CREATED) -->
        <activity
            android:name=".activities.CartActivity"
            android:exported="false" />

        <!-- StepItemsActivity - Items by step category -->
        <activity
            android:name=".activities.StepItemsActivity"
            android:exported="false" />

        <!-- OrderDetailActivity - Order detail -->
        <activity
            android:name=".activities.OrderDetailActivity"
            android:exported="false" />

    </application>

</manifest>
